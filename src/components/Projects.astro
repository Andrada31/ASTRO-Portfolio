---
import svgl from "../../public/png/s5.png";
import placeholder from "../../public/png/placeholder.png";
import ProjectCard from "@/React/ProjectCard";

interface Project {
  title: string;
  image: ImageMetadata;
  link: string;
  preview: string;
  status: string;
}

const projects: Project[] = [
  {
    title: "MoviesForDevs",
    image: placeholder as ImageMetadata,
    link: "https://github.com/gothsec/MoviesForDevs",
    preview: "https://movies-for-devs.vercel.app",
    status: "Deployed",
  },
  {
    title: "StockIn",
    image: placeholder as ImageMetadata,
    link: "https://github.com/gothsec/stockin-demo",
    preview: "https://stockin-demo.vercel.app",
    status: "On Development",
  },
  {
    title: "Svgl.app",
    image: svgl as ImageMetadata,
    link: "https://github.com/pheralb/svgl",
    preview: "https://svgl.app",
    status: "Contributor",
  },
  {
    title: "Rifas Velez Web",
    image: placeholder as ImageMetadata,
    link: "https://github.com/Buga-Software/rifasvelez-web",
    preview: "https://www.rifasvelez.com",
    status: "Deployed",
  },
];
---

<section
  id="projects"
  class="py-12 border-t border-[#ffffff10] text-[var(--white)]"
>
  <div class="max-w-5xl mx-auto">
    <h2 class="text-lg text-[var(--sec)] mb-2 shiny-sec">My work</h2>
    <h3 class="text-4xl md:text-5xl font-medium mb-8">Projects</h3>

    <div
      class="grid grid-cols-1 md:grid-cols-2 gap-14 justify-center items-center"
    >
      <div class="flex justify-center md:justify-start">
        <ProjectCard
          client:load
          text_m="Transfer Learning in Astronomy"
          text_s="Local"
          image="/ASTRO-Portfolio/png/s5.png"
          logo="/ASTRO-Portfolio/svg/TensorFlow.svg"
          codeLink="https://github.com/Andrada31/Transfer-Learning-in-Astronomy"
          externalLink="https://kaggle.com/writeups/andradaparaczki/transfer-learning-in-the-detection-and-classificat"
          media={[
            { type: 'video', url: '/ASTRO-Portfolio/videos/transfer-learning.mp4' }
          ]}
          overview="My Bachelor's Thesis explores how Transfer Learning can help in the training of pretrained CNN models (VGG16, ResNet50, EfficientNet) for classification, and YOLO object detection algorithms (YOLOv8-c and YOLOv11n) to classify and detect deep space objects (DSOs). The web interface allows users to run live inference on telescope imagery, visualize activation maps using Grad-CAM, and compare model performances."
          techStack={[
            { name: 'Python', icon: '/ASTRO-Portfolio/svg/python.svg' },
            { name: 'TensorFlow', icon: '/ASTRO-Portfolio/svg/TensorFlow.svg' },
            { name: 'PyTorch', icon: '/ASTRO-Portfolio/svg/PyTorch.svg' },
            { name: 'React', icon: '/ASTRO-Portfolio/svg/react.svg' },
            { name: 'TailwindCSS', icon: '/ASTRO-Portfolio/svg/tailwindcss.svg' },
            { name: 'Vite', icon: '/ASTRO-Portfolio/svg/vite.svg' }
          ]}
        />
      </div>
      <div class="flex justify-center md:justify-start">
        <ProjectCard
          client:load
          text_m="NEXUS Ecosystem"
          text_s="LIVE"
          image="/ASTRO-Portfolio/png/s3.png"
          logo="/ASTRO-Portfolio/svg/react.svg"
          codeLink="https://nexus.e-uvt.ro/"
          externalLink="https://nexus.e-uvt.ro/"
          media={[
            { type: 'video', url: '/ASTRO-Portfolio/videos/nexus.mp4' }
          ]}
          overview="NEXUS Ecosystem is a submission management platform featuring JSON-defined dynamic forms, granular group-based authorization, configurable workflows, status history, and external institutional integrations (Webcon BPS). The architecture relies on a robust Backend (NestJS) for access rules and validations, a dynamic Frontend (Next.js & React) for user interactions, and PostgreSQL as the single source of truth for relational data and JSONB responses."
          techStack={[
            { name: 'Next.js', icon: '/ASTRO-Portfolio/svg/next.svg' },
            { name: 'React', icon: '/ASTRO-Portfolio/svg/react.svg' },
            { name: 'TypeScript', icon: '/ASTRO-Portfolio/svg/typeScript.svg' },
            { name: 'Node.js', icon: '/ASTRO-Portfolio/svg/nodejs.svg' },
            { name: 'Tailwind CSS', icon: '/ASTRO-Portfolio/svg/tailwindcss.svg' },
            { name: 'Docker', icon: '/ASTRO-Portfolio/svg/docker.svg' }
          ]}
        />
      </div>
      <div class="flex justify-center md:justify-start">
        <ProjectCard
          client:load
          text_m="Blackboard"
          text_s="In progress.."
          image="/ASTRO-Portfolio/png/b1.png"
          logo="/ASTRO-Portfolio/svg/next.svg"
          codeLink="https://github.com/Andrada31/Blackboard"
          externalLink="#"
          media={[
            { type: 'video', url: '/ASTRO-Portfolio/videos/blackboard.mp4' }
          ]}
          overview="A modern, digital drawing application. Features include multi-layer support with visibility and opacity controls, drawing tools (pencil, eraser, shapes, text, fill), and an intuitive floating toolbar interface. State is managed via React Context API, using HTML5 Canvas API for real-time drawing operations."
          techStack={[
            { name: 'Next.js', icon: '/ASTRO-Portfolio/svg/next.svg' },
            { name: 'React', icon: '/ASTRO-Portfolio/svg/react.svg' },
            { name: 'TypeScript', icon: '/ASTRO-Portfolio/svg/typeScript.svg' },
            { name: 'Tailwind CSS', icon: '/ASTRO-Portfolio/svg/tailwindcss.svg' },
            { name: 'HTML5', icon: '/ASTRO-Portfolio/svg/HTML5.svg' }
          ]}
        />
      </div>
      <div class="flex justify-center md:justify-start">
        <ProjectCard
          client:load
          text_m="Japan Parallax"
          text_s="Demo"
          image="/ASTRO-Portfolio/png/japan.png"
          logo="/ASTRO-Portfolio/svg/HTML5.svg"
          codeLink="https://github.com/Andrada31/Japan-Parallax"
          externalLink="#"
          media={[
            { type: 'video', url: '/ASTRO-Portfolio/videos/japan-parallax.mp4' }
          ]}
          overview="A visually stunning showcase website demonstrating advanced CSS and JavaScript parallax scrolling techniques, beautifully themed around Japanese culture and landscapes."
          techStack={[
            { name: 'HTML5', icon: '/ASTRO-Portfolio/svg/HTML5.svg' },
            { name: 'CSS3', icon: '/ASTRO-Portfolio/svg/CSS3.svg' },
            { name: 'JavaScript', icon: '/ASTRO-Portfolio/svg/javaScript.svg' }
          ]}
        />
      </div>
    </div>
    <a
      target="_blank"
      href="https://github.com/Andrada31"
      aria-label="GitHub"
      class="w-full flex items-center justify-center gap-2 mt-14 text-[var(--white-icon)] hover:text-white transition duration-300 ease-in-out border border-[var(--white-icon-tr)] p-3 rounded-full hover:bg-[var(--white-icon-tr)] hover:scale-105"
    >
      <span class="md:text-lg text-md">More projects on</span>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
        class="size-6"
      >
        <path
          d="M12.001 2C6.47598 2 2.00098 6.475 2.00098 12C2.00098 16.425 4.86348 20.1625 8.83848 21.4875C9.33848 21.575 9.52598 21.275 9.52598 21.0125C9.52598 20.775 9.51348 19.9875 9.51348 19.15C7.00098 19.6125 6.35098 18.5375 6.15098 17.975C6.03848 17.6875 5.55098 16.8 5.12598 16.5625C4.77598 16.375 4.27598 15.9125 5.11348 15.9C5.90098 15.8875 6.46348 16.625 6.65098 16.925C7.55098 18.4375 8.98848 18.0125 9.56348 17.75C9.65098 17.1 9.91348 16.6625 10.201 16.4125C7.97598 16.1625 5.65098 15.3 5.65098 11.475C5.65098 10.3875 6.03848 9.4875 6.67598 8.7875C6.57598 8.5375 6.22598 7.5125 6.77598 6.1375C6.77598 6.1375 7.61348 5.875 9.52598 7.1625C10.326 6.9375 11.176 6.825 12.026 6.825C12.876 6.825 13.726 6.9375 14.526 7.1625C16.4385 5.8625 17.276 6.1375 17.276 6.1375C17.826 7.5125 17.476 8.5375 17.376 8.7875C18.0135 9.4875 18.401 10.375 18.401 11.475C18.401 15.3125 16.0635 16.1625 13.8385 16.4125C14.201 16.725 14.5135 17.325 14.5135 18.2625C14.5135 19.6 14.501 20.675 14.501 21.0125C14.501 21.275 14.6885 21.5875 15.1885 21.4875C19.259 20.1133 21.9999 16.2963 22.001 12C22.001 6.475 17.526 2 12.001 2Z"
        ></path>
      </svg>
    </a>
  </div>
</section>
