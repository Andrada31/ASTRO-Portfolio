---
import BaseLayout from "../layouts/Layout.astro";
---

<BaseLayout title="404 – Page Not Found">
  <main
    class="flex flex-col items-center justify-center min-h-screen gap-6 text-center px-4"
  >
    <!-- relative container so absolute positioning is scoped here -->
    <div id="astronaut-anchor" class="relative w-[12em] h-[12em]">
      <!-- Ghost: invisible, holds layout space -->
      <img
        id="astronaut-ghost"
        src="/ASTRO-Portfolio/png/astronaut.png"
        alt=""
        aria-hidden="true"
        class="w-[12em] invisible pointer-events-none"
        draggable="false"
      />
      <!-- Real astronaut: sits exactly on top of ghost -->
      <img
        id="astronaut"
        src="/ASTRO-Portfolio/png/astronaut.png"
        alt="Astronaut"
        class="w-[12em] absolute top-0 left-0 select-none hover:cursor-grab active:cursor-grabbing"
        style="animation: move 10s ease-in-out infinite;"
        draggable="false"
      />
    </div>

    <h1 class="text-5xl text-white mt-12">Houston, we have a problem!</h1>
    <!-- <p class="text-xl text-gray-400">Looks like you're lost in space.</p> -->
    <p class="text-md text-gray-400 max-w-md leading-relaxed">
      You are here because this page does not exist.<br />
      The route you followed may be broken or was never created.
    </p>

    <a
      href="/"
      class="mt-2 inline-flex items-center gap-2 px-6 py-2 rounded-full border text-white border-white/20 hover:bg-white/10 transition"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="#6c88da"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="w-5 h-5"
      >
        <circle cx="12" cy="12" r="10"></circle>
        <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"></path>
        <path d="M2 12h20"></path>
      </svg>

      Back to Earth
    </a>
  </main>
</BaseLayout>

<style>
  @keyframes move {
    0%,
    100% {
      transform: translateY(0px) rotate(-2deg);
    }
    50% {
      transform: translateY(-20px) rotate(2deg);
    }
  }

  #astronaut.dragging {
    cursor: grabbing !important;
    filter: drop-shadow(0 0 18px rgba(150, 180, 255, 0.45));
  }
</style>

<script>
  const astronaut = document.getElementById("astronaut") as HTMLImageElement;
  const ghost = document.getElementById("astronaut-ghost") as HTMLImageElement;

  let isDragging = false;
  let originX = 0;
  let originY = 0;

  function startDrag(clientX: number, clientY: number) {
    const rect = astronaut.getBoundingClientRect();
    originX = clientX - rect.left;
    originY = clientY - rect.top;

    astronaut.style.animation = "none";
    astronaut.style.position = "fixed";
    astronaut.style.left = rect.left + "px";
    astronaut.style.top = rect.top + "px";
    astronaut.style.width = rect.width + "px";
    astronaut.style.margin = "0";
    astronaut.style.zIndex = "50";
    astronaut.style.transition = "none";
    astronaut.classList.add("dragging");
    isDragging = true;
  }

  function onMove(clientX: number, clientY: number) {
    if (!isDragging) return;
    astronaut.style.left = clientX - originX + "px";
    astronaut.style.top = clientY - originY + "px";
  }

  function stopDrag() {
    if (!isDragging) return;
    isDragging = false;
    astronaut.classList.remove("dragging");

    const ghostRect = ghost.getBoundingClientRect();
    astronaut.style.transition =
      "left 0.6s cubic-bezier(0.34,1.56,0.64,1), top 0.6s cubic-bezier(0.34,1.56,0.64,1)";
    astronaut.style.left = ghostRect.left + "px";
    astronaut.style.top = ghostRect.top + "px";

    setTimeout(() => {
      astronaut.style.position = "";
      astronaut.style.left = "";
      astronaut.style.top = "";
      astronaut.style.width = "";
      astronaut.style.margin = "";
      astronaut.style.zIndex = "";
      astronaut.style.transition = "";
      astronaut.style.animation = "move 10s ease-in-out infinite";
    }, 620);
  }

  astronaut.addEventListener("mousedown", (e) => {
    startDrag(e.clientX, e.clientY);
    e.preventDefault();
  });
  astronaut.addEventListener(
    "touchstart",
    (e) => {
      startDrag(e.touches[0].clientX, e.touches[0].clientY);
      e.preventDefault();
    },
    { passive: false },
  );

  document.addEventListener("mousemove", (e) => onMove(e.clientX, e.clientY));
  document.addEventListener(
    "touchmove",
    (e) => {
      onMove(e.touches[0].clientX, e.touches[0].clientY);
      e.preventDefault();
    },
    { passive: false },
  );

  document.addEventListener("mouseup", stopDrag);
  document.addEventListener("touchend", stopDrag);
</script>
